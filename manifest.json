{
  "name": "AI Bookmark Sorter",
  "version": "1.3",
  "manifest_version": 3,
  "description": "Uses Chrome's built-in AI (Gemini Nano) to sort bookmarks into the best-fitting folder.",
  "permissions": ["bookmarks", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
